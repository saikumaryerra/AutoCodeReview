{
  "name": "auto-code-review",
  "version": "1.0.0",
  "description": "AI-powered pull request review system using Claude CLI",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "express": "^4.18.2",
    "better-sqlite3": "^11.0.0",
    "octokit": "^4.0.2",
    "azure-devops-node-api": "^14.1.0",
    "node-cron": "^3.0.3",
    "winston": "^3.11.0",
    "zod": "^3.22.4",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "@types/node": "^20.11.24",
    "@types/express": "^4.17.21",
    "@types/better-sqlite3": "^7.6.8",
    "@types/cors": "^2.8.17",
    "@types/uuid": "^9.0.7",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.7.1",
    "vitest": "^1.3.1",
    "concurrently": "^8.2.2"
  }
}
